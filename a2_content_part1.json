                "wasn't"
              ],
              "answer": "didn't"
            }
          ]
        },
        "ex2": {
          "title": "Write the past form",
          "questions": [
            {
              "q": "study → _____",
              "answer": "studied"
            },
            {
              "q": "stop → _____",
              "answer": "stopped"
            },
            {
              "q": "see → _____",
              "answer": "saw"
            },
            {
              "q": "have → _____",
              "answer": "had"
            },
            {
              "q": "come → _____",
              "answer": "came"
