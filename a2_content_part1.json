  "chapters": [
    {
      "slug": "past-simple",
      "num": 1,
      "label": "Past Simple",
      "subtitle": "I worked · She didn't work · Did you work?",
      "slides": [
        {
          "h2": "What is the Past Simple?",
          "intro": "We use the Past Simple to talk about <strong>finished actions in the past</strong>. The action is over.",
          "rows": [
            [
              "Yesterday",
              "I <strong>worked</strong> until 9pm yesterday."
            ],
            [
              "Last week",
              "We <strong>visited</strong> grandma last week."
            ],
            [
              "In 2020",
              "She <strong>moved</strong> to Madrid in 2020."
            ],
            [
              "Time markers",
              "yesterday · last week · two days ago · in 2010"
            ]
          ]
        },
        {
          "h2": "Regular verbs — add -ed",
          "intro": "Most verbs add <strong>-ed</strong> to make the past form. Same form for all subjects.",
          "rows": [
            [
              "work → worked",
              "I/you/he/she/we/they <strong>worked</strong>."
            ],
            [
              "play → played",
              "She <strong>played</strong> tennis."
            ],
            [
              "Spelling: -e + d",
              "live → liv<strong>ed</strong> · hope → hop<strong>ed</strong>"
            ],
            [
              "Spelling: y → ied",
              "study → stud<strong>ied</strong> · cry → cr<strong>ied</strong>"
            ],
            [
              "Double consonant",
              "stop → sto<strong>pped</strong> · plan → pla<strong>nned</strong>"
            ]
          ],
          "watch_out": "All subjects use the same past form: I worked, she worked, they worked. NOT 'she workeds'."
        },
        {
          "h2": "Irregular verbs — must memorise",
          "intro": "Many common verbs are <strong>irregular</strong> — they don't follow the -ed rule.",
          "rows": [
            [
              "go → went",
              "I <strong>went</strong> to the cinema."
            ],
            [
              "have → had",
              "She <strong>had</strong> a great time."
            ],
            [
              "see → saw",
              "We <strong>saw</strong> the new film."
            ],
            [
              "eat → ate",
              "They <strong>ate</strong> pizza."
            ],
            [
              "buy → bought",
              "He <strong>bought</strong> a new phone."
            ],
            [
              "come → came",
              "Maria <strong>came</strong> to my house."
            ]
          ]
        },
        {
          "h2": "Negative and questions — use 'did'",
          "intro": "For negatives and questions, use <strong>did/didn't</strong> + the <strong>base verb</strong> (no -ed!).",
          "rows": [
            [
              "Negative",
              "I <strong>didn't go</strong> to school. (NOT didn't went)"
            ],
            [
              "Question",
              "<strong>Did</strong> you <strong>see</strong> the film? (NOT did you saw)"
            ],
            [
              "Short answer",
              "Yes, I did. / No, I didn't."
            ],
            [
              "Was/were — different",
              "I <strong>was</strong> tired. <strong>Were</strong> you home?"
            ]
          ],
          "watch_out": "After 'did/didn't' use the BASE verb, never the past form. 'Did you went' is wrong — it must be 'Did you go?'"
        },
        {
          "h2": "Recap",
          "rows": [
            [
              "Regular +ed",
              "worked, played, studied, stopped"
            ],
            [
              "Irregular",
              "went, had, saw, ate, bought, came"
            ],
            [
              "Negative",
              "didn't + base verb"
            ],
            [
              "Question",
              "Did + subject + base verb?"
            ]
          ],
          "cta": true
        }
      ],
      "worksheet": {
        "ex1": {
          "title": "Choose the correct past form",
          "questions": [
