          "example": "We <b>went</b> home.",
          "completion": "go → ______",
          "answer": "went"
        },
        {
          "id": "saw",
          "term": "saw",
          "meaning": "irregular past of see",
          "synonym": "see → saw",
          "example": "I <b>saw</b> her yesterday.",
          "completion": "see → ______",
          "answer": "saw"
        },
        {
          "id": "didnt",
          "term": "didn't",
          "meaning": "negative past — use base verb",
          "synonym": "didn't + base",
          "example": "I <b>didn't go</b>. (NOT didn't went)",
          "completion": "I ______ go (negative)",
          "answer": "didn't"
        },
        {
          "id": "did_q",
          "term": "Did you...?",
          "meaning": "past question — use base verb",
          "synonym": "Did + base",
          "example": "<b>Did you see</b> it? (NOT did you saw)",
          "completion": "______ you see it?",
          "answer": "Did"
        }
      ]
    },
    {
      "slug": "past-continuous",
      "num": 2,
      "label": "Past Continuous",
      "subtitle": "I was working · While she was sleeping · What were you doing?",
      "slides": [
        {
          "h2": "Form: was/were + verb-ing",
          "intro": "We use the Past Continuous for <strong>actions in progress at a moment in the past</strong>.",
          "rows": [
            [
              "I / he / she / it",
              "<strong>was</strong> + verb-ing — I <strong>was working</strong>"
            ],
            [
              "you / we / they",
              "<strong>were</strong> + verb-ing — they <strong>were playing</strong>"
            ],
            [
              "Negative",
              "I <strong>wasn't</strong> sleeping · they <strong>weren't</strong> ready"
            ],
            [
              "Question",
              "<strong>Were</strong> you working? · <strong>Was</strong> she there?"
            ]
          ]
        },
        {
          "h2": "When do we use it?",
          "intro": "Three main situations:",
          "rows": [
            [
              "Action in progress",
              "At 8pm I <strong>was watching</strong> TV."
            ],
            [
              "Two parallel actions",
              "She <strong>was reading</strong> while he <strong>was cooking</strong>."
            ],
            [
              "Interrupted action",
              "I <strong>was sleeping</strong> when the phone rang."
            ],
            [
              "Setting a scene",
              "It <strong>was raining</strong>, the wind <strong>was blowing</strong>..."
            ]
          ]
        },
        {
          "h2": "Past Simple vs Past Continuous",
          "intro": "These two work together. Past Continuous = the long action. Past Simple = the short action that interrupts it.",
          "rows": [
            [
              "Long action",
              "I <strong>was eating</strong> dinner..."
            ],
            [
              "Short interruption",
              "...<strong>when</strong> the doorbell <strong>rang</strong>."
            ],
            [
              "Both together",
              "While she <strong>was studying</strong>, the lights <strong>went</strong> out."
            ]
          ],
          "watch_out": "Use Past Simple after WHEN for the short action, Past Continuous after WHILE for the long action."
        },
        {
          "h2": "Recap",
          "rows": [
            [
              "Form",
              "was/were + verb-ing"
            ],
            [
              "Use 1",
              "Action in progress at a past moment"
            ],
            [
              "Use 2",
              "Two parallel past actions"
            ],
            [
              "Use 3",
              "Long action interrupted by short action"
            ]
          ],
          "cta": true
        }
      ],
      "worksheet": {
        "ex1": {
          "title": "Choose the correct form",
          "questions": [
            {
              "q": "I _____ TV when you called.",
              "options": [
