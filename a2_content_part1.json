            }
          ]
        }
      },
      "game": [
        {
          "id": "was",
          "term": "was + ing",
          "meaning": "past continuous for I/he/she/it",
          "synonym": "was + verb-ing",
          "example": "I <b>was working</b>.",
          "completion": "I ______ working.",
          "answer": "was"
        },
        {
          "id": "were",
          "term": "were + ing",
          "meaning": "past continuous for you/we/they",
