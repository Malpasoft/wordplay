              "answer": "bought"
            },
            {
              "q": "We _____ pizza for dinner.",
              "options": [
                "ate",
                "eated",
                "eat"
              ],
              "answer": "ate"
            },
            {
              "q": "They _____ tennis on Sunday.",
              "options": [
                "played",
                "plaied",
                "playd"
              ],
              "answer": "played"
            },
            {
              "q": "He _____ his keys.",
              "options": [
                "losed",
                "losted",
                "lost"
              ],
              "answer": "lost"
            },
            {
              "q": "I _____ TV last night.",
              "options": [
                "watched",
                "watcht",
                "wached"
              ],
              "answer": "watched"
            },
            {
              "q": "Maria _____ to Paris in 2019.",
              "options": [
                "traveled",
