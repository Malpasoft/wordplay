    {
      "slug": "present-perfect-intro",
      "num": 3,
      "label": "Present Perfect — Introduction",
      "subtitle": "I have visited · She hasn't seen · Have you ever...?",
      "slides": [
        {
          "h2": "Form: have/has + past participle",
          "intro": "Use this when the past connects to NOW. The past action has a result or relevance in the present.",
          "rows": [
            [
              "I / you / we / they",
              "<strong>have</strong> + past participle — I <strong>have visited</strong>"
            ],
            [
              "he / she / it",
              "<strong>has</strong> + past participle — she <strong>has seen</strong>"
            ],
            [
              "Negative",
              "I <strong>haven't</strong> finished · he <strong>hasn't</strong> arrived"
            ],
            [
              "Question",
              "<strong>Have</strong> you eaten? · <strong>Has</strong> she called?"
            ]
          ]
        },
        {
          "h2": "Past participles",
          "intro": "Regular verbs: same as past simple (-ed). Irregular verbs: third form.",
          "rows": [
            [
              "Regular",
              "work → worked → <strong>worked</strong>"
            ],
            [
              "see",
              "see → saw → <strong>seen</strong>"
            ],
            [
              "go",
              "go → went → <strong>gone</strong>"
            ],
            [
              "eat",
              "eat → ate → <strong>eaten</strong>"
            ],
            [
              "have",
              "have → had → <strong>had</strong>"
            ],
            [
              "be",
              "be → was/were → <strong>been</strong>"
            ]
          ]
        },
        {
          "h2": "When to use it",
          "intro": "Three main situations at A2 level:",
          "rows": [
            [
              "Life experience",
              "I <strong>have visited</strong> Paris twice."
            ],
            [
              "Recent action with present effect",
              "She <strong>has just arrived</strong>. (she's here now)"
            ],
            [
              "With ever / never",
              "<strong>Have</strong> you <strong>ever</strong> tried sushi? — No, I <strong>have never</strong> tried it."
            ],
            [
              "Unfinished time",
              "I <strong>have worked</strong> here for 3 years. (still working here)"
            ]
          ],
          "watch_out": "DON'T use Present Perfect with finished time markers like 'yesterday', 'last week', 'in 2010'. Use Past Simple instead. Yesterday I went (NOT yesterday I have gone)."
        },
        {
          "h2": "Recap",
          "rows": [
            [
              "Form",
              "have/has + past participle"
            ],
            [
              "Use",
              "Past action connecting to NOW"
            ],
            [
              "With",
              "ever, never, just, already, yet, for, since"
            ],
            [
              "Don't use with",
              "yesterday, last week, ago, in 2010"
            ]
          ],
          "cta": true
        }
      ],
