              "answer": "were playing"
            },
            {
              "q": "What _____ you _____ at 8pm?",
              "options": [
                "were doing",
                "did do",
                "was doing"
              ],
              "answer": "were doing"
            },
            {
              "q": "She _____ when the bell rang.",
              "options": [
                "sleep",
                "was sleeping",
                "were sleeping"
              ],
              "answer": "was sleeping"
            },
            {
              "q": "While I _____, my phone rang.",
              "options": [
                "cooked",
                "was cooking",
                "were cooking"
              ],
              "answer": "was cooking"
            },
            {
              "q": "It _____ heavily this morning.",
              "options": [
                "was raining",
                "rained",
                "were raining"
